# ============================================================
#  .env — copy file នេះ ហើយកំណត់តម្លៃរបស់អ្នក
# ============================================================

PORT=3322

# PostgreSQL connection
DATABASE_URL=postgresql://postgres:password@localhost:5432/water_monitor

# JWT secret key — ប្ដូរជា string វែងស្មុគស្មាញ
JWT_SECRET=change-this-to-a-long-random-secret-string

# API Key សម្រាប់ ESP32 (ត្រូវដូចនឹង API_KEY ក្នុង .ino)
API_KEY=your-secret-api-key-here
